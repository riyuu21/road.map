# Backend
AUTH_SECRET=change-me-to-a-long-random-string
PROVIDER_KEYS_SECRET=change-me-to-a-different-long-random-string
FRONTEND_URL=http://localhost:3000

# Optional database. Without this, the backend uses in-memory storage.
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=roadmap

# Google OAuth. In Google Cloud Console set the redirect URI to:
# http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Optional server-owned fallback keys for local/admin generation only.
# Signed-in users generate with their own saved provider keys instead of these.
AI_PROVIDER_ORDER=groq,gemini,openrouter,mistral
# GROQ_API_KEY=*** GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY=*** GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_API_KEY=*** OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# MISTRAL_API_KEY=*** MISTRAL_MODEL=mistral-small-latest
# AI_BASE_URL=
# AI_API_KEY=*** AI_MODEL=
